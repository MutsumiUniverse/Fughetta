using Gtk 4.0;
using Adw 1;

template $SourceActionRow: Adw.ActionRow {
    activatable: true;
    title-lines: 1;
    subtitle-lines: 2;

    GestureClick {
        button: 1;
        released => $left_click_cb() swapped;
    }

    GestureClick {
        button: 3;
        released => $right_click_cb() swapped;
    }
}
